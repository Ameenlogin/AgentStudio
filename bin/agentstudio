#!/usr/bin/env bash
# Agent Studio command-line launcher (macOS / Linux).
# Installed on your PATH as `agentstudio` (and `agent` if that name is free).
#   agentstudio run        start Agent Studio and open it in your browser
#   agentstudio install    update to the latest version and re-setup
#   agentstudio stop       stop a running instance (frees port 8000)
#   agentstudio where      print the install directory
REPO="${AGENT_STUDIO_HOME:-$HOME/AgentStudio}"

if [ ! -d "$REPO" ]; then
  echo "Agent Studio is not installed at $REPO."
  echo "Install it with:"
  echo '  curl -fsSL https://raw.githubusercontent.com/Ameenlogin/AgentStudio/main/install.sh | bash'
  exit 1
fi

case "${1:-run}" in
  run|start|"")           exec bash "$REPO/run.command" ;;
  install|update|upgrade)
                          echo "Updating Agent Studio (pulling latest from GitHub + rebuilding the UI)..."
                          exec bash "$REPO/install.sh" ;;
  stop)                   lsof -ti tcp:8000 2>/dev/null | xargs kill -9 2>/dev/null; echo "Agent Studio stopped." ;;
  where|dir)              echo "$REPO" ;;
  -h|--help|help)         echo "Usage: agentstudio [run|update|stop|where]" ;;
  *) echo "Unknown command: $1"; echo "Usage: agentstudio [run|update|stop|where]"; exit 1 ;;
esac
