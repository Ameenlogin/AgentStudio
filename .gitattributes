# Keep Windows batch files CRLF so cmd.exe parses labels/goto reliably,
# and keep Unix shell launchers LF so bash/zsh run them correctly — even
# when the repo is downloaded as a zip without git's autocrlf.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.command   text eol=lf
*.sh        text eol=lf
bin/agentstudio text eol=lf

# Treat common binaries as binary (no EOL munging).
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
*.pdf       binary
*.zip       binary
